# 复制为 backend/.env 后填写。不要提交真实密钥。
DEEPSEEK_API_KEY=sk-your-api-key

# 本地开发密钥；生产环境必须替换为高强度随机字符串。
JWT_SECRET=replace-with-a-random-secret

# Redis 可选。没有 Redis 时设为 0，聊天、Graph 和 SQLite 仍可运行。
REDIS_ENABLED=0
REDIS_URL=redis://localhost:6379/0

# 业务消息和 LangGraph checkpoint 分开存储。
DATABASE_URL=sqlite+aiosqlite:///./chatbot.db
CHECKPOINT_DB_PATH=./checkpoints.db

# 五层 Context Engineering 默认参数；初次运行建议保持默认值。
CONTEXT_MAX_INPUT_TOKENS=32000
CONTEXT_MICROCOMPACT_TTL_SECONDS=1800
CONTEXT_SESSION_MEMORY_RATIO=0.45
CONTEXT_COLLAPSE_RATIO=0.62
CONTEXT_FULL_COMPACT_RATIO=0.82
CONTEXT_PTL_TRUNCATION_RATIO=0.95
CONTEXT_KEEP_RECENT_TURNS=2

# 仅当本地代理破坏 TLS 证书链时临时启用，生产环境不要开启。
DEEPSEEK_INSECURE_TLS=0
